<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Профиль — VARTOCHAT</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen p-6">
    <div class="max-w-md mx-auto bg-zinc-900 rounded-3xl p-8">
        <div class="flex justify-between mb-8">
            <h1 class="text-4xl font-bold text-emerald-500">VARTOCHAT</h1>
            <a href="/" class="text-xl text-zinc-400 hover:text-white">← Чаты</a>
        </div>

        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for cat, msg in messages %}
                    <div class="mb-6 p-4 rounded-2xl {{ 'bg-emerald-600' if cat=='success' else 'bg-red-500' }}">
                        {{ msg }}
                    </div>
                {% endfor %}
            {% endif %}
        {% endwith %}

        <form method="POST" action="/update_profile" enctype="multipart/form-data" class="space-y-8">
            <div class="text-center">
                <img id="preview" src="{{ user.avatar }}" class="w-40 h-40 rounded-full mx-auto border-4 border-emerald-600 object-cover">
                <label class="mt-6 block bg-zinc-800 hover:bg-zinc-700 transition py-4 rounded-2xl cursor-pointer">
                    Выбрать новую аватарку
                    <input type="file" name="avatar" accept="image/*" onchange="previewImage(this)" class="hidden">
                </label>
            </div>

            <input type="text" name="name" value="{{ user.name }}" class="w-full bg-zinc-800 rounded-2xl px-6 py-4" placeholder="Имя">
            <input type="text" name="username" value="{{ user.username }}" class="w-full bg-zinc-800 rounded-2xl px-6 py-4" placeholder="Username">

            <div class="space-y-4 pt-6 border-t border-zinc-700">
                <label class="flex items-center gap-3"><input type="checkbox" name="show_last_seen" {% if user.show_last_seen %}checked{% endif %}> Показывать "был(а) в сети"</label>
                <label class="flex items-center gap-3"><input type="checkbox" name="show_online" {% if user.show_online %}checked{% endif %}> Показывать статус "онлайн"</label>
            </div>

            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 py-5 rounded-2xl text-xl font-semibold transition">
                Сохранить изменения
            </button>
        </form>

        <!-- КНОПКА ВЫХОДА -->
        <button onclick="logout()"
                class="mt-8 w-full bg-red-600 hover:bg-red-700 py-5 rounded-2xl text-xl font-semibold transition flex items-center justify-center gap-2">
            <span>🚪</span> Выйти из аккаунта
        </button>
    </div>

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('preview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }

        function logout() {
            if (confirm('Вы действительно хотите выйти из аккаунта?')) {
                window.location.href = '/logout';
            }
        }
    </script>
</body>
</html>
